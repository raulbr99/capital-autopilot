# Capital.com DEMO credentials
# 1. Crea cuenta en capital.com y entra en la cuenta DEMO
# 2. Settings -> API integrations -> Generate API Key (te pedira una "API password" propia)
# 3. Rellena los 3 valores y renombra este archivo a .env.local

CAPITAL_API_KEY=tu_api_key
CAPITAL_IDENTIFIER=tu_email@ejemplo.com
CAPITAL_PASSWORD=tu_api_password

# Base URL DEMO (no la cambies salvo que sepas lo que haces)
CAPITAL_BASE_URL=https://demo-api-capital.backend-capital.com

# --- Piloto automatico (cron) ---
# Interruptor durable: "true" = el cron ABRE operaciones de verdad.
# Dejalo en "false" hasta que quieras armarlo.
AUTOPILOT_ARMED=false

# Secreto para proteger /api/bot/cron. Genera uno largo aleatorio.
# Vercel lo envia automaticamente como "Authorization: Bearer <CRON_SECRET>".
CRON_SECRET=cambia_esto_por_un_secreto_largo

# --- Supabase (persistencia: config, trades, equity, logs) ---
# Si no los pones, el bot funciona en memoria (se reinicia al reiniciar el server).
SUPABASE_URL=https://TU_PROYECTO.supabase.co
SUPABASE_SERVICE_ROLE_KEY=tu_service_role_key

# --- Notificaciones (opcional) ---
# Telegram: crea un bot con @BotFather y obten tu chat_id con @userinfobot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Discord: Server Settings -> Integrations -> Webhooks -> copia la URL
DISCORD_WEBHOOK_URL=
